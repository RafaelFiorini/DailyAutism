spring:
  jackson:
    default-property-inclusion: non-null
  application:
    name: DailyAutism
  datasource:
    url: jdbc:mysql://localhost:3306/dailyautism
    username: SEU USERNAME
    password: SUA SENHA
    driver-class-name: com.mysql.cj.jdbc.Driver
  jpa:
